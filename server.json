{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "ai.rolli/mcp",
  "description": "Social media search and analytics across X, Reddit, Bluesky, YouTube, and more",
  "repository": {
    "url": "https://github.com/rolliinc/rolli-mcp",
    "source": "github"
  },
  "version": "1.1.5",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@rolli/mcp",
      "version": "1.1.5",
      "transport": { "type": "stdio" },
      "environmentVariables": [
        {
          "name": "ROLLI_API_TOKEN",
          "description": "Rolli API token (purchase at rolli.ai)",
          "isRequired": true,
          "isSecret": true,
          "format": "string"
        },
        {
          "name": "ROLLI_USER_ID",
          "description": "Rolli user ID (optional, defaults to \"rolli-mcp\")",
          "isRequired": false,
          "isSecret": false,
          "format": "string"
        }
      ]
    }
  ]
}
